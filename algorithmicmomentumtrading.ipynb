BENCHMARKS = {"XU100": "XU100.IS", "XU030": "XU030.IS"}

# --- Evren bandı ---
LIQ_EXCLUDE_TOP = 0        # En likit N hisse dışlanır (mega/verimli kesim)
LIQ_RANK_MAX = 120          # Likidite sırası üst sınırı
ABS_LIQ_FLOOR = 20_000_000  # Medyan günlük TL hacim tabanı
LIQ_WINDOW = 63

# --- Sinyal ---
MOM_WINDOWS = (63, 126, 252)   # 3 / 6 / 12 aylık momentum karması
MOM_SKIP = 5                   # Kısa vadeli geri dönüş dışlaması
VOL_WINDOW = 126               # Risk ayarı volatilite penceresi

# --- Portföy ---
TOP_N = 3                      # Konsantre sepet
MAX_POS_WEIGHT = 1           # Tek isim tavanı (piyango konsantrasyonu frenli)
N_TRANCHES = 3                 # Dilimli rebalans (zamanlama şansı öldürülür)
REBALANCE_DAYS = 21          # ~Aylık dengeleme

# --- Koruma ---
REGIME_SMA = 200               # Endeks rejim filtresi
ATR_WINDOW = 22                # Chandelier ATR penceresi
STOP_ATR_MULT = 3.0            # Zirveden 3 x ATR düşüşte pozisyon kesilir

# --- Muhasebe ---
YEARS_OF_DATA = 10             # 10 yıl çekilir; 5y/1y alt pencereler türetilir
INITIAL_CAPITAL = 100_000.0
TRANSACTION_COST = 0       # işlem başına binde 3 (komisyon + kayma)
CASH_YIELD_ANNUAL = 0.30       # !!! Faiz ortamına göre GÜNCEL TUTUN !!!
TRADING_DAYS = 252
WARMUP = 260
MAX_WORKERS = 12

# --- Protokol ---
GO_MIN_ALPHA_YEAR_RATIO = 0.60


# =============================================================================
# 1) VERİ KATMANI
# =============================================================================
def _fetch_one(symbol: str):
    """Tek sembol: kapanış, TL hacim, yüksek, düşük serileri."""
    try:
        df = yf.Ticker(symbol).history(period=f"{YEARS_OF_DATA}y",
                                       interval="1d", auto_adjust=True)
        if df is None or df.empty or len(df) < 300:
            return None
        if df.index.tz is not None:
            df.index = df.index.tz_localize(None)
        return (df["Close"].where(df["Close"] > 0),
                (df["Close"] * df["Volume"]).fillna(0.0),
                df["High"].where(df["High"] > 0),
                df["Low"].where(df["Low"] > 0))
    except Exception:
        return None


def fetch_panels():
    """Tüm havuzu paralel indirir; panelleri ve benchmarkları döndürür."""
    closes, vols, highs, lows = {}, {}, {}, {}
    with ThreadPoolExecutor(max_workers=MAX_WORKERS) as ex:
        futs = {ex.submit(_fetch_one, f"{t}.IS"): t for t in UNIVERSE_TICKERS}
        for fut in as_completed(futs):
            t = futs[fut]
            res = fut.result()
            if res is None:
                continue
            closes[t], vols[t], highs[t], lows[t] = res

    close_panel = pd.DataFrame(closes).sort_index().ffill()
    idx = close_panel.index
    vol_panel = pd.DataFrame(vols).sort_index().reindex(idx).fillna(0.0)
    high_panel = pd.DataFrame(highs).sort_index().reindex(idx).ffill()
    low_panel = pd.DataFrame(lows).sort_index().reindex(idx).ffill()
    logger.info(f"Havuz: {close_panel.shape[1]} hisse x {len(idx)} gün "
                f"({len(UNIVERSE_TICKERS)} istendi; kalanlar atlandı)")

    benches = {}
    for name, sym in BENCHMARKS.items():
        res = _fetch_one(sym)
        if res is not None:
            benches[name] = res[0].reindex(idx).ffill()
    if not benches:
        benches["EşitAğırlık"] = close_panel.mean(axis=1)
    return close_panel, vol_panel, high_panel, low_panel, benches


# =============================================================================
# 2) SİNYAL, EVREN, ATR, TAVAN
# =============================================================================
def momentum_scores(panel: pd.DataFrame) -> pd.DataFrame:
    """Risk-ayarlı kesitsel momentum skoru (tamamı geçmişe bakar)."""
    base = panel.shift(MOM_SKIP)
    raw = sum(base / base.shift(w) - 1.0 for w in MOM_WINDOWS) / len(MOM_WINDOWS)
    vol = panel.pct_change().rolling(VOL_WINDOW).std()
    return raw / vol.replace(0, np.nan)


def eligibility_mask(vol_panel: pd.DataFrame):
    """Noktasal orta-ölçek bandı üyeliği (look-ahead yok)."""
    liq = vol_panel.rolling(LIQ_WINDOW).median()
    rank = liq.rank(axis=1, ascending=False)
    mask = (rank > LIQ_EXCLUDE_TOP) & (rank <= LIQ_RANK_MAX) & (liq >= ABS_LIQ_FLOOR)
    return mask, mask.sum(axis=1)


def atr_panel(close, high, low) -> pd.DataFrame:
    """Klasik Wilder ATR, panel bazında vektörel."""
    prev_c = close.shift(1)
    tr = pd.concat([high - low, (high - prev_c).abs(), (low - prev_c).abs()],
                   keys=["a", "b", "c"]).groupby(level=1).max()
    return tr.reindex(close.index).ewm(alpha=1 / ATR_WINDOW,
                                       min_periods=ATR_WINDOW,
                                       adjust=False).mean()


def _cap_weights(w: pd.Series, cap: float = MAX_POS_WEIGHT) -> pd.Series:
    """
    Şelale usulü tavanlama: fazla pay yalnızca tavan ALTINDAKİLERE
    dağıtılır; kimse kalmazsa artan pay nakitte kalır.
    """
    w = w.copy()
    for _ in range(len(w)):
        over = w > cap + 1e-12
        if not over.any():
            break
        excess = float((w[over] - cap).sum())
        w[over] = cap
        under = (w < cap - 1e-12) & (w > 0)
        if not under.any() or w[under].sum() <= 0:
            break
        w[under] = w[under] + excess * w[under] / w[under].sum()
    return w.clip(upper=cap)


# =============================================================================
# 3) MOTOR: dilimli rotasyon + Chandelier stop
# =============================================================================
def _tranche_weights(panel, scores, abs_mom, eligible, regime_on, atr, offset):
    """
    Tek dilimin günlük ağırlık matrisi.
      Rebalans günü: bant içi en yüksek TOP_N skor (mutlak momentum > 0 ve
      rejim açıksa), skor ağırlıklı + %40 tavanlı.
      Ara günler: her pozisyon için zirve takibi; kapanış zirveden
      STOP_ATR_MULT x ATR altına inerse pozisyon kesilir (pay nakitte).
    Tüm kararlar t kapanışıyla alınır; muhasebe t+1'de uygular.
    """
    dates = panel.index
    weights = pd.DataFrame(0.0, index=dates, columns=panel.columns)
    current = pd.Series(0.0, index=panel.columns)
    high_water: dict[str, float] = {}

    for k, dt in enumerate(dates):
        if k >= WARMUP + offset and (k - WARMUP - offset) % REBALANCE_DAYS == 0:
            row = scores.loc[dt].where(eligible.loc[dt]).dropna()
            picks = []
            if regime_on.loc[dt]:
                for tkr in row.sort_values(ascending=False).index:
                    if len(picks) >= TOP_N:
                        break
                    if abs_mom.loc[dt].get(tkr, np.nan) > 0:
                        picks.append(tkr)

            current = pd.Series(0.0, index=panel.columns)
            if picks:
                sc = row[picks].clip(lower=0)
                raw = (sc / sc.sum()) if sc.sum() > 0 \
                    else pd.Series(1.0 / len(picks), index=picks)
                capped = _cap_weights(raw)
                current[capped.index] = capped.values
            high_water = {t: float(panel.loc[dt, t])
                          for t in current[current > 0].index}

        elif k > WARMUP:
            for tkr in list(high_water):
                px = float(panel.loc[dt, tkr])
                high_water[tkr] = max(high_water[tkr], px)
                a = atr.loc[dt, tkr]
                if np.isfinite(a) and px < high_water[tkr] - STOP_ATR_MULT * a:
                    current[tkr] = 0.0
                    del high_water[tkr]

        weights.iloc[k] = current
    return weights


def run_strategy(panel, vol_panel, high_panel, low_panel, index_close):
    """Uçtan uca strateji koşusu: ağırlıklar -> muhasebe -> sermaye eğrisi."""
    scores = momentum_scores(panel)
    abs_mom = panel.shift(MOM_SKIP) / panel.shift(MOM_SKIP + 252) - 1.0
    regime_on = index_close > index_close.rolling(REGIME_SMA).mean()
    eligible, depth = eligibility_mask(vol_panel)
    atr = atr_panel(panel, high_panel, low_panel)

    offsets = [i * (REBALANCE_DAYS // N_TRANCHES) for i in range(N_TRANCHES)]
    weights = sum(_tranche_weights(panel, scores, abs_mom, eligible,
                                   regime_on, atr, o)
                  for o in offsets) / N_TRANCHES

    # --- Muhasebe: t ağırlığı t+1 getirisine; maliyet turnover'dan;
    #     yatırılmayan pay günlük bileşik nakit getirisi kazanır ---
    w_exec = weights.shift(1).fillna(0.0)
    rets = panel.pct_change().fillna(0.0)
    cash_daily = (1 + CASH_YIELD_ANNUAL) ** (1 / TRADING_DAYS) - 1

    invested = w_exec.sum(axis=1)
    port_ret = (w_exec * rets).sum(axis=1) + (1 - invested) * cash_daily
    turnover = w_exec.diff().abs().sum(axis=1).fillna(invested)
    port_ret = port_ret - turnover * TRANSACTION_COST
    n_trades = int((w_exec.diff().abs() > 1e-9).sum().sum())

    port_ret.iloc[0] = 0.0
    equity = INITIAL_CAPITAL * (1 + port_ret).cumprod()
    return equity, weights, n_trades, depth


# =============================================================================
# 4) METRİKLER + PROTOKOL
# =============================================================================
def sharpe_ratio(daily: pd.Series) -> float:
    """Nakit getirisi üzerindeki fazla getiriden yıllık Sharpe."""
    rf = (1 + CASH_YIELD_ANNUAL) ** (1 / TRADING_DAYS) - 1
    ex = daily - rf
    return 0.0 if ex.std() < 1e-9 or len(ex) < 2 else \
        float(ex.mean() / ex.std() * np.sqrt(TRADING_DAYS))


def summarize(equity: pd.Series) -> dict:
    d = equity.pct_change().dropna()
    yrs = max(len(equity) / TRADING_DAYS, 1e-9)
    cagr = (equity.iloc[-1] / equity.iloc[0]) ** (1 / yrs) - 1
    mdd = float((equity / equity.cummax() - 1).min())
    return {"Toplam Getiri %": round((equity.iloc[-1] / equity.iloc[0] - 1) * 100, 2),
            "CAGR %": round(cagr * 100, 2),
            "Max Drawdown %": round(mdd * 100, 2),
            "Sharpe": round(sharpe_ratio(d), 2),
            "Calmar": round(cagr / abs(mdd), 2) if mdd < 0 else np.nan}


def yearly_alpha_table(equity: pd.Series, bench: pd.Series) -> pd.DataFrame:
    df = pd.DataFrame({"s": equity, "b": bench}).dropna()
    rows = []
    for year, grp in df.groupby(df.index.year):
        if len(grp) < 40:
            continue
        rs = grp["s"].iloc[-1] / grp["s"].iloc[0] - 1
        rb = grp["b"].iloc[-1] / grp["b"].iloc[0] - 1
        rows.append({"Yıl": year, "Strateji %": round(rs * 100, 1),
                     "Benchmark %": round(rb * 100, 1),
                     "Alfa (puan)": round((rs - rb) * 100, 1)})
    return pd.DataFrame(rows)


def go_no_go(strat_sharpe, bench_sharpe, yearly):
    checks = []
    k1 = strat_sharpe > bench_sharpe
    checks.append(f"K1 Sharpe > benchmark: {strat_sharpe:.2f} vs "
                  f"{bench_sharpe:.2f} -> {'✓' if k1 else '✗'}")
    ratio = float((yearly["Alfa (puan)"] > 0).mean()) if len(yearly) else 0.0
    k2 = ratio >= GO_MIN_ALPHA_YEAR_RATIO
    checks.append(f"K2 Yılların >=%{GO_MIN_ALPHA_YEAR_RATIO*100:.0f}'ında "
                  f"pozitif alfa: %{ratio*100:.0f} -> {'✓' if k2 else '✗'}")
    return k1 and k2, checks


def _report_window(title, equity, bench_eq, bench_name):
    """Verilen pencerede strateji vs benchmark bloğu basar."""
    e = equity / equity.iloc[0] * INITIAL_CAPITAL
    b = bench_eq / bench_eq.iloc[0] * INITIAL_CAPITAL
    sm, bm = summarize(e), summarize(b)
    print(f"\n{title} ({e.index[0].date()} -> {e.index[-1].date()})")
    print("-" * 70)
    print(f"{'':18s}{'STRATEJİ':>22s}{bench_name + ' B&H':>22s}")
    for k in ["Toplam Getiri %", "CAGR %", "Max Drawdown %", "Sharpe", "Calmar"]:
        print(f"{k:18s}{sm[k]:>22}{bm[k]:>22}")
    return sm, bm


# =============================================================================
# 5) ANA AKIŞ
# =============================================================================
def main():
    print("=" * 78)
    print(" BIST MOMENTUM - NİHAİ SÜRÜM (Orta-Ölçek Konsantre Momentum)")
    print(f" Top {TOP_N} skor ağırlıklı (tavan %{MAX_POS_WEIGHT*100:.0f}) | "
          f"stop {STOP_ATR_MULT}xATR{ATR_WINDOW} | rejim SMA{REGIME_SMA} | "
          f"{N_TRANCHES} dilim x {REBALANCE_DAYS}g")
    print("=" * 78)

    panel, vol_panel, high_panel, low_panel, benches = fetch_panels()
    bench_name = "XU100" if "XU100" in benches else next(iter(benches))
    regime_src = benches[bench_name]

    equity, weights, n_trades, depth = run_strategy(
        panel, vol_panel, high_panel, low_panel, regime_src)

    eq = equity.iloc[WARMUP:]
    be = benches[bench_name].iloc[WARMUP:]
    d = depth.iloc[WARMUP:]
    print(f"\nEvren derinliği: ort {d.mean():.0f}, min {d.min():.0f} "
          f"| toplam işlem: {n_trades}")
    if d.min() < TOP_N * 3:
        print("  UYARI: Bant bazı dönemlerde sığ (erken yıllar); "
              "o dönem sonuçlarını temkinli okuyun.")

    # --- Üç ufuklu rapor: tüm dönem / son 5 yıl / son 12 ay ---
    sm_full, bm_full = _report_window(
        f"TÜM DÖNEM (~{YEARS_OF_DATA} yıl)", eq, be, bench_name)

    cut5 = eq.index[-1] - pd.DateOffset(years=5)
    _report_window("SON 5 YIL", eq.loc[eq.index >= cut5],
                   be.loc[be.index >= cut5], bench_name)

    cut1 = eq.index[-1] - pd.DateOffset(years=1)
    _report_window("SON 12 AY", eq.loc[eq.index >= cut1],
                   be.loc[be.index >= cut1], bench_name)

    # --- Yıllık alfa + GO/NO-GO (tüm dönem üzerinden) ---
    bench_eq_full = INITIAL_CAPITAL * be / be.iloc[0]
    yearly = yearly_alpha_table(eq / eq.iloc[0] * INITIAL_CAPITAL, bench_eq_full)
    print(f"\nTAKVİM YILI ALFASI ({bench_name}'e karşı):")
    print(yearly.to_string(index=False))
    verdict, checks = go_no_go(sm_full["Sharpe"], bm_full["Sharpe"], yearly)
    print(f"\nGO/NO-GO HÜKMÜ: {'GO' if verdict else 'NO-GO'}")
    for c in checks:
        print("  " + c)

    # --- Güncel portföy ---
    last_w = weights.iloc[-1]
    held = last_w[last_w > 1e-4].sort_values(ascending=False)
    print("\nGÜNCEL PORTFÖY:")
    if held.empty:
        print("  %100 NAKİT (rejim kapalı / stop kesmiş / aday yok)")
    else:
        for t, wgt in held.items():
            print(f"  {t:8s} %{wgt*100:.1f}")
        print(f"  NAKİT    %{(1-held.sum())*100:.1f}")

    # --- Kayıtlar ---
    out = Path("results"); out.mkdir(exist_ok=True)
    pd.DataFrame({"Strateji": equity, bench_name: benches[bench_name]
                  }).to_csv(out / "equity_final.csv", encoding="utf-8-sig")
    yearly.to_csv(out / "final_yearly_alpha.csv", index=False,
                  encoding="utf-8-sig")
    chg = weights.diff().abs().sum(axis=1)
    log_rows = [{"Tarih": dt.date(),
                 "Sepet": ", ".join(f"{t}:{weights.loc[dt, t]*100:.0f}%"
                                    for t in weights.columns
                                    if weights.loc[dt, t] > 1e-4) or "NAKİT"}
                for dt in weights.index[chg > 1e-9]]
    pd.DataFrame(log_rows).to_csv(out / "final_rebalance_log.csv",
                                  index=False, encoding="utf-8-sig")
    print(f"\nÇıktılar '{out}/' klasörüne kaydedildi "
          "(sermaye eğrileri, yıllık alfa, rebalans günlüğü).")

    print("\nUYARILAR (ayrıntı README.md'de):")
    print("  - Sonuçlar nominal TL'dir ve survivorship kalıntısı içerir.")
    print("  - -%45+ drawdown tarihsel örneklemdir, tavan değildir.")
    print("  - Sıra: paper trading (min 3 ay) -> küçük sermaye -> kademeli.")
    print("  - Simülasyondur; yatırım tavsiyesi değildir.")


if __name__ == "__main__":
    main()
